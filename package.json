{
  "name": "overlay",
  "version": "1.0.0",
  "description": "OAI Overlay Specification",
  "author": {
    "name": "OpenAPI Initiative - Overlay Working Group",
    "email": "tsc@openapis.org",
    "url": "https://openapis.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OAI/Overlay-Specification.git"
  },
  "license": "Apache-2.0",
  "readmeFilename": "README.md",
  "dependencies": {
    "cheerio": "^1.0.0-rc.5",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0",
    "respec": "35.1.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "bump-cli": "^2.8.2",
    "markdownlint-cli": "^0.41.0",
    "mdv": "^1.3.4",
    "prettier": "^3.3.3",
    "yaml": "^2.5.0"
  },
  "keywords": [
    "API",
    "OAI",
    "OAS",
    "OpenAPI",
    "Overlay",
    "Specification",
    "Swagger"
  ],
  "scripts": {
    "build": "npm run structured-bump && npm run structured-speakeasy && npm run wildcard-bump && npm run wildcard-speakeasy",
    "structured-bump": "bump overlay examples/structured.openapi.yaml examples/structured.overlay.yaml > examples/structured.bump.yaml",
    "structured-speakeasy": "speakeasy overlay apply -s examples/structured.openapi.yaml -o examples/structured.overlay.yaml --out examples/structured.speakeasy.yaml",
    "wildcard-bump": "bump overlay examples/wildcard.openapi.yaml examples/wildcard.overlay.yaml > examples/wildcard.bump.yaml",
    "wildcard-speakeasy": "speakeasy overlay apply -s examples/wildcard.openapi.yaml -o examples/wildcard.overlay.yaml --out examples/wildcard.speakeasy.yaml"
  }
}
